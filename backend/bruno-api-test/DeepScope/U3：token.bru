meta {
  name: U3：token (refresh)
  type: http
  seq: 6
}

post {
  url: http://127.0.0.1:8002/api/Auth/replaceToken
  body: none
  auth: inherit
}

headers {
  authorization: Bearer eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJ0ZXN0LXVzZXIiLCJpYXQiOjE3ODE3NTA1NzIsImV4cCI6MTc4MTgzNjk3Mn0.test-token-payload
}

settings {
  encodeUrl: true
  timeout: 0
}

example {
  name: fail=true (模拟刷新失败 → 401)
  
  request: {
    url: http://127.0.0.1:8002/api/Auth/replaceToken?fail=true
    method: POST
    mode: none
    headers: {
      authorization: Bearer eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJ0ZXN0LXVzZXIiLCJpYXQiOjE3ODE3NTA1NzIsImV4cCI6MTc4MTgzNjk3Mn0.test-token-payload
    }
  }
  
  response: {
    headers: {
      server: uvicorn
      content-type: application/json
    }
  
    status: {
      code: 401
      text: Unauthorized
    }
  
    body: {
      type: json
      content: '''
        {
          "detail": "Simulated refresh failure for testing"
        }
      '''
    }
  }
}

example {
  name: normal（成功刷新）
  
  request: {
    url: http://127.0.0.1:8002/api/Auth/replaceToken
    method: POST
    mode: none
    headers: {
      authorization: Bearer eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJ0ZXN0LXVzZXIiLCJpYXQiOjE3ODE3NTA1NzIsImV4cCI6MTc4MTgzNjk3Mn0.test-token-payload
    }
  }
  
  response: {
    headers: {
      date: Thu, 18 Jun 2026 06:25:22 GMT
      server: uvicorn
      content-length: 211
      content-type: application/json
    }
  
    status: {
      code: 200
      text: OK
    }
  
    body: {
      type: json
      content: '''
        {
          "Success": true,
          "StatusCode": null,
          "Message": null,
          "Data": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJ0ZXN0LXVzZXIiLCJpYXQiOjE3ODE3NTA1NzIsImV4cCI6MTc4MTg1MDMyMn0.ms6OysImjA3ztihG-NWsKsjQUrdfIBQCVBGJHRkPFr8"
        }
      '''
    }
  }
}
