meta {
  name: U3：testToken (生成)
  type: http
  seq: 7
}

get {
  url: http://127.0.0.1:8002/api/Auth/testToken
  body: none
  auth: inherit
}

settings {
  encodeUrl: true
  timeout: 0
}

example {
  name: fail=true (返回无效token)
  
  request: {
    url: http://127.0.0.1:8002/api/Auth/testToken?fail=true
    method: GET
    mode: none
  }
  
  response: {
    headers: {
      server: uvicorn
      content-type: application/json
    }
  
    status: {
      code: 200
      text: OK
    }
  
    body: {
      type: json
      content: '''
        {
          "token": "INVALID_TOKEN_FOR_TESTING"
        }
      '''
    }
  }
}

